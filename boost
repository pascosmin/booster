#!/usr/bin/env python3
"""Sound Boost - PulseAudio/PipeWire volume control with boost beyond 100%."""
import tkinter as tk
import subprocess
import re
import time
import signal
import os

MAX_VOL = 300
AUTO_REFRESH_MS = 2500
USER_LOCK_SECS  = 2.5

CLARITY_SINK      = "boost_clarity"
CLARITY_STATE_FILE = os.path.expanduser("~/.cache/boost_pre_clarity_sink")
# mbeq 15 bands: ~50/100/156/220/311/440/622/880/1250/1750/2500/3500/5000/10k/20k Hz
# Strategy: cut mud in low-mids, gentle lift in presence/air — no aggressive boost to avoid clip
CLARITY_CTRL = "0,0,0,-3,-4,-1,0,0,0,0,1,2,1,1,0"
CLARITY_VOL  = 80   # initial % for clarity sink — compensates EQ gains, prevents clipping

CLARITY_INFO = (
    "✦ Clarity active  ·  cuts 220–311 Hz (mud/boom)  ·  "
    "lifts 2.5–5 kHz (presence, speech clarity)  ·  opens 10 kHz (air)  ·  "
    "starts at 80% to avoid distortion — raise the Clarity EQ slider if needed"
)

BG       = "#1e1e2e"
BG2      = "#181825"
SURFACE  = "#313244"
TEXT     = "#cdd6f4"
SUBTEXT  = "#a6adc8"
BLUE     = "#89b4fa"
LAVENDER = "#b4befe"
GREEN    = "#a6e3a1"
PEACH    = "#fab387"
RED      = "#f38ba8"
PURPLE   = "#cba6f7"

# ── pactl helpers ─────────────────────────────────────────────────────────────

def _pactl(*args):
    r = subprocess.run(["pactl"] + list(args), capture_output=True, text=True)
    return r.stdout

def parse_sinks():
    out = _pactl("list", "sinks")
    sinks, cur = [], None
    for line in out.splitlines():
        if m := re.match(r"^Sink #(\d+)", line):
            cur = {"index": m[1], "name": "", "desc": "", "vol": 100, "mute": False}
            sinks.append(cur)
        elif cur:
            if m := re.match(r"\s+Description:\s+(.+)", line):
                cur["desc"] = m[1]
            elif m := re.match(r"\s+Name:\s+(.+)", line):
                cur["name"] = m[1]
            elif m := re.match(r"\s+Volume:.*?(\d+)%", line):
                cur["vol"] = int(m[1])
            elif m := re.match(r"\s+Mute:\s+(yes|no)", line):
                cur["mute"] = m[1] == "yes"
    return sinks

def parse_inputs():
    out = _pactl("list", "sink-inputs")
    inputs, cur, in_props = [], None, False
    for line in out.splitlines():
        if m := re.match(r"^Sink Input #(\d+)", line):
            cur = {"index": m[1], "app": "", "vol": 100, "mute": False, "owner_module": ""}
            inputs.append(cur)
            in_props = False
        elif cur:
            if re.match(r"\s+Properties:", line):
                in_props = True
            if not in_props:
                if m := re.match(r"\s+Volume:.*?(\d+)%", line):
                    cur["vol"] = int(m[1])
                elif m := re.match(r"\s+Mute:\s+(yes|no)", line):
                    cur["mute"] = m[1] == "yes"
                elif m := re.match(r"\s+Owner Module:\s+(\d+)", line):
                    cur["owner_module"] = m[1]
            else:
                if m := re.match(r'\s+application\.name\s*=\s*"(.+)"', line):
                    cur["app"] = m[1]
                elif not cur["app"]:
                    if m := re.match(r'\s+media\.name\s*=\s*"(.+)"', line):
                        cur["app"] = m[1]
    return [i for i in inputs if i["app"]]

def set_sink_vol(idx, pct):
    subprocess.run(["pactl", "set-sink-volume", str(idx), f"{int(pct)}%"],
                   capture_output=True)

def set_input_vol(idx, pct):
    subprocess.run(["pactl", "set-sink-input-volume", str(idx), f"{int(pct)}%"],
                   capture_output=True)

def get_default_sink():
    return _pactl("get-default-sink").strip()

def move_inputs_to_sink(sink_name):
    for inp in parse_inputs():
        subprocess.run(["pactl", "move-sink-input", inp["index"], sink_name],
                       capture_output=True)

def cleanup_stale_clarity():
    """Unload any leftover clarity LADSPA modules from previous sessions."""
    out = subprocess.run(["pactl", "list", "modules", "short"],
                         capture_output=True, text=True).stdout
    for line in out.splitlines():
        parts = line.split(None, 2)
        if len(parts) >= 2 and parts[1] == "module-ladspa-sink":
            args = parts[2] if len(parts) > 2 else ""
            if f"sink_name={CLARITY_SINK}" in args:
                subprocess.run(["pactl", "unload-module", parts[0]], capture_output=True)
    if os.path.exists(CLARITY_STATE_FILE):
        os.remove(CLARITY_STATE_FILE)

# ── UI components ─────────────────────────────────────────────────────────────

APP_ICONS = {
    "firefox": "🦊", "chromium": "🌐", "chrome": "🌐", "brave": "🦁",
    "spotify": "🎵", "vlc": "📺", "mpv": "🎬", "rhythmbox": "🎶",
    "telegram": "✈️", "discord": "🎮", "zoom": "📹", "teams": "👥",
    "slack": "💬", "skype": "📞",
}

def app_icon(name):
    lo = name.lower()
    for key, icon in APP_ICONS.items():
        if key in lo:
            return icon
    return "🔈"


class VolumeRow(tk.Frame):
    def __init__(self, parent, label, vol, on_change, **kw):
        super().__init__(parent, bg=BG2, **kw)
        self._on_change = on_change
        self._last_user = 0
        self.configure(pady=4)

        tk.Label(self, text=label, bg=BG2, fg=TEXT,
                 font=("Sans", 9), anchor="w", width=32
                 ).pack(side="left", padx=(10, 4))

        self._pct_var = tk.StringVar(value=f"{vol}%")
        self._pct_lbl = tk.Label(self, textvariable=self._pct_var,
                                  bg=BG2, fg=self._pct_color(vol),
                                  font=("Mono", 9, "bold"), width=6, anchor="e")
        self._pct_lbl.pack(side="right", padx=(4, 10))

        self._var = tk.IntVar(value=vol)
        self._slider = tk.Scale(
            self, from_=0, to=MAX_VOL, orient="horizontal",
            variable=self._var, showvalue=0,
            bg=BG2, fg=TEXT, troughcolor=SURFACE,
            activebackground=BLUE, highlightthickness=0,
            sliderlength=18, bd=0,
            command=self._user_changed,
        )
        self._slider.pack(side="left", fill="x", expand=True, padx=4)
        self._update_slider_color(vol)

    def _pct_color(self, v):
        if v > 150: return RED
        if v > 100: return PEACH
        return GREEN

    def _update_slider_color(self, v):
        color = RED if v > 150 else (PEACH if v > 100 else GREEN)
        self._slider.configure(foreground=color)
        self._pct_lbl.configure(fg=color)

    def _user_changed(self, _=None):
        v = self._var.get()
        self._last_user = time.time()
        self._pct_var.set(f"{v}%")
        self._update_slider_color(v)
        self._on_change(v)

    def sync_vol(self, vol):
        if time.time() - self._last_user < USER_LOCK_SECS:
            return
        self._var.set(vol)
        self._pct_var.set(f"{vol}%")
        self._update_slider_color(vol)


class Section(tk.Frame):
    def __init__(self, parent, title, **kw):
        super().__init__(parent, bg=BG, **kw)
        hdr = tk.Frame(self, bg=BG)
        hdr.pack(fill="x", padx=12, pady=(10, 4))
        tk.Label(hdr, text=title, bg=BG, fg=BLUE,
                 font=("Sans", 10, "bold")).pack(side="left")
        tk.Frame(hdr, bg=SURFACE, height=1).pack(side="left", fill="x",
                                                   expand=True, padx=(8, 0), pady=5)
        self.rows_frame = tk.Frame(self, bg=BG2, relief="flat")
        self.rows_frame.pack(fill="x", padx=12, pady=(0, 6))


class BoostApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Sound Boost")
        self.configure(bg=BG)
        self.resizable(True, True)
        self.minsize(560, 200)
        self.protocol("WM_DELETE_WINDOW", self._on_close)

        self._sink_rows:  dict[str, VolumeRow] = {}
        self._input_rows: dict[str, VolumeRow] = {}

        self._clarity_module:    str | None = None
        self._pre_clarity_sink:  str | None = None

        cleanup_stale_clarity()  # remove leftovers from any previous session
        signal.signal(signal.SIGTERM, lambda *_: self._on_close())
        signal.signal(signal.SIGHUP,  lambda *_: self._on_close())
        self._build_ui()
        self._full_refresh()

    # ── UI build ──────────────────────────────────────────────────────────────

    def _build_ui(self):
        top = tk.Frame(self, bg=BG)
        top.pack(fill="x", padx=16, pady=(14, 2))
        tk.Label(top, text="🔊 Sound Boost", bg=BG, fg=PURPLE,
                 font=("Sans", 15, "bold")).pack(side="left")
        tk.Label(top, text="PipeWire / PulseAudio", bg=BG, fg=SUBTEXT,
                 font=("Sans", 9)).pack(side="left", padx=(10, 0), pady=3)

        tk.Button(top, text="↺ Refresh", bg=SURFACE, fg=TEXT, relief="flat",
                  activebackground=LAVENDER, activeforeground=BG,
                  font=("Sans", 9), bd=0, padx=8, pady=2,
                  command=self._full_refresh).pack(side="right")

        self._clarity_btn = tk.Button(
            top, text="✦ Clarity: OFF", bg=SURFACE, fg=SUBTEXT, relief="flat",
            activebackground=GREEN, activeforeground=BG,
            font=("Sans", 9), bd=0, padx=8, pady=2,
            command=self._toggle_clarity,
        )
        self._clarity_btn.pack(side="right", padx=(0, 6))

        # Info bar — visible only when Clarity is ON
        self._clarity_bar = tk.Label(
            self, text=CLARITY_INFO,
            bg=SURFACE, fg=BLUE, font=("Sans", 8),
            pady=5, padx=14, anchor="w", wraplength=700, justify="left",
        )

        self._sink_section = Section(self, "Output Devices")
        self._sink_section.pack(fill="x")

        self._app_section = Section(self, "Applications")
        self._app_section.pack(fill="both", expand=True)

        self._no_apps_lbl = tk.Label(
            self._app_section.rows_frame,
            text="No audio applications running",
            bg=BG2, fg=SUBTEXT, font=("Sans", 9), pady=10,
        )

        foot = tk.Frame(self, bg=BG)
        foot.pack(fill="x", padx=16, pady=(0, 10))
        self._status = tk.Label(foot, text="", bg=BG, fg=SUBTEXT, font=("Sans", 8))
        self._status.pack(side="left")
        tk.Label(foot, text=f"Max boost: {MAX_VOL}%", bg=BG, fg=SUBTEXT,
                 font=("Sans", 8)).pack(side="right")

    # ── Clarity EQ ───────────────────────────────────────────────────────────

    def _toggle_clarity(self):
        if self._clarity_module is None:
            self._enable_clarity()
        else:
            self._disable_clarity()

    def _enable_clarity(self):
        # Clean up any stale module before loading a new one
        cleanup_stale_clarity()

        sinks = [s for s in parse_sinks() if s["name"] != CLARITY_SINK]
        if not sinks:
            self._status.configure(text="Clarity: no output device found")
            return

        self._pre_clarity_sink = get_default_sink()
        sink_names = [s["name"] for s in sinks]
        master = (self._pre_clarity_sink if self._pre_clarity_sink in sink_names
                  else sinks[0]["name"])
        # persist so we can restore if the app is killed (SIGKILL)
        open(CLARITY_STATE_FILE, "w").write(self._pre_clarity_sink)

        result = subprocess.run(
            ["pactl", "load-module", "module-ladspa-sink",
             f"sink_name={CLARITY_SINK}",
             f"sink_master={master}",
             "plugin=mbeq_1197", "label=mbeq",
             f"control={CLARITY_CTRL}"],
            capture_output=True, text=True,
        )

        if result.returncode != 0 or not result.stdout.strip().isdigit():
            self._status.configure(
                text="Clarity: install swh-plugins →  sudo apt install swh-plugins"
            )
            return

        self._clarity_module = result.stdout.strip()
        subprocess.run(["pactl", "set-sink-volume", CLARITY_SINK, f"{CLARITY_VOL}%"],
                       capture_output=True)
        move_inputs_to_sink(CLARITY_SINK)
        subprocess.run(["pactl", "set-default-sink", CLARITY_SINK], capture_output=True)

        self._clarity_btn.configure(bg=GREEN, fg=BG, text="✦ Clarity: ON")
        self._clarity_bar.pack(fill="x", after=self.children.get("!frame"))  # below title bar
        self._full_refresh()

    def _disable_clarity(self):
        target = self._pre_clarity_sink
        if not target:
            real = [s for s in parse_sinks() if s["name"] != CLARITY_SINK]
            target = real[0]["name"] if real else None

        if target:
            move_inputs_to_sink(target)
            subprocess.run(["pactl", "set-default-sink", target], capture_output=True)

        if self._clarity_module:
            subprocess.run(["pactl", "unload-module", self._clarity_module],
                           capture_output=True)
            self._clarity_module = None

        self._pre_clarity_sink = None
        if os.path.exists(CLARITY_STATE_FILE):
            os.remove(CLARITY_STATE_FILE)
        self._clarity_bar.pack_forget()
        self._clarity_btn.configure(bg=SURFACE, fg=SUBTEXT, text="✦ Clarity: OFF")
        self._full_refresh()

    def _on_close(self):
        if self._clarity_module:
            self._disable_clarity()
        self.destroy()

    # ── Refresh ───────────────────────────────────────────────────────────────

    def _full_refresh(self):
        sinks  = parse_sinks()
        inputs = parse_inputs()

        # Hide the LADSPA loopback stream — it's internal, not a real app
        visible_inputs = [i for i in inputs
                          if i["owner_module"] != self._clarity_module]

        self._update_section(
            self._sink_rows,
            self._sink_section.rows_frame,
            [{"index": s["index"],
              "label": (f"✦  Clarity EQ (processor)"
                        if s["name"] == CLARITY_SINK
                        else f"🔊  {self._short(s['desc'] or s['name'], 28)}"),
              "vol": s["vol"]} for s in sinks],
            lambda idx, v: set_sink_vol(idx, v),
        )

        self._update_section(
            self._input_rows,
            self._app_section.rows_frame,
            [{"index": i["index"],
              "label": f"{app_icon(i['app'])}  {self._short(i['app'], 30)}",
              "vol": i["vol"]} for i in visible_inputs],
            lambda idx, v: set_input_vol(idx, v),
        )

        if visible_inputs:
            self._no_apps_lbl.pack_forget()
        else:
            self._no_apps_lbl.pack(fill="x")

        self._status.configure(
            text=f"Last refresh: {time.strftime('%H:%M:%S')}  |  "
                 f"{len(sinks)} output(s)  {len(visible_inputs)} app(s)"
        )

        self.after(AUTO_REFRESH_MS, self._full_refresh)

    def _update_section(self, rows, frame, items, make_cmd):
        current_ids = {it["index"] for it in items}
        for idx in list(rows):
            if idx not in current_ids:
                rows[idx].destroy()
                del rows[idx]
        for item in items:
            idx = item["index"]
            if idx in rows:
                rows[idx].sync_vol(item["vol"])
            else:
                row = VolumeRow(
                    frame, item["label"], item["vol"],
                    on_change=lambda v, i=idx, c=make_cmd: c(i, v),
                )
                row.pack(fill="x")
                rows[idx] = row

    @staticmethod
    def _short(s, n):
        return s if len(s) <= n else s[:n - 1] + "…"


if __name__ == "__main__":
    app = BoostApp()
    app.mainloop()
